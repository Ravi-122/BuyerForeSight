Website:</strong> \r\n       <span>\r\n        <a href={`http://${user.website}`} >\r\n        {user.website}\r\n       </a>\r\n       </span>\r\n      </p>\r\n\r\n      </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default UserDetail;"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAClD,OAASC,SAAS,KAAQ,kBAAkB,CAC5C,MAAM,UAAU,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAEjB,QAAS,CAAAC,UAAUA,CAAA,CAAG,CACpB,KAAM,CAAEC,EAAG,CAAC,CAAGN,SAAS,CAAC,CAAC,CAC1B,KAAM,CAACO,IAAI,CAAEC,OAAO,CAAC,CAAGT,QAAQ,CAAC,IAAI,CAAC,CAEtCD,SAAS,CAAC,IAAM,CACdW,KAAK,CAAC,8CAA8CH,EAAE,EAAE,CAAC,CACtDI,IAAI,CAACC,GAAG,EAAIA,GAAG,CAACC,IAAI,CAAC,CAAC,CAAC,CACvBF,IAAI,CAACG,IAAI,EAAIL,OAAO,CAACK,IAAI,CAAC,CAAC,CAChC,CAAC,CAAE,CAACP,EAAE,CAAC,CAAC,CAGV,GAAI,CAACC,IAAI,CAAE,CACT,mBACEL,IAAA,QAAKY,SAAS,CAAC,kBAAkB,CAAAC,QAAA,cAC/Bb,IAAA,QACEc,GAAG,CAAC,WAAW,CACfC,GAAG,CAAC,gBAAgB,CACpBH,SAAS,CAAC,MAAM,CACjB,CAAC,CACC,CAAC,CAEV,CAEE,mBACEV,KAAA,QAAKU,SAAS,CAAC,kBAAkB,CAAAC,QAAA,eAC/Bb,IAAA,WAAQY,SAAS,CAAC,UAAU,CAACI,OAAO,CAAEA,CAAA,GAAMC,MAAM,CAACC,OAAO,CAACC,IAAI,CAAC,CAAE,CAAAN,QAAA,CAAC,MAAI,CAAQ,CAAC,cAChFX,KAAA,QAAKU,SAAS,CAAC,MAAM,CAAAC,QAAA,eAACb,IAAA,OAAAa,QAAA,CAAKR,IAAI,CAACe,IAAI,CAAK,CAAC,cAE1ClB,KAAA,QAAKU,SAAS,CAAC,MAAM,CAAAC,QAAA,eACrBX,KAAA,MAAAW,QAAA,eAAGb,IAAA,WAAAa,QAAA,CAAQ,QAAM,CAAQ,CAAC,cAAAb,IAAA,SAAAa,QAAA,CAAOR,IAAI,CAACgB,KAAK,CAAO,CAAC,EAAG,CAAC,cACvDnB,KAAA,MAAAW,QAAA,eAAGb,IAAA,WAAAa,QAAA,CAAQ,QAAM,CAAQ,CAAC,IAAC,cAAAb,IAAA,SAAAa,QAAA,CAAOR,IAAI,CAACiB,KAAK,CAAO,CAAC,EAAG,CAAC,cACxDpB,KAAA,MAAAW,QAAA,eAAGb,IAAA,WAAAa,QAAA,CAAQ,UAAQ,CAAQ,CAAC,IAAC,cAAAb,IAAA,SAAAa,QAAA,CAAOR,IAAI,CAACkB,OAAO,CAACH,IAAI,CAAO,CAAC,EAAG,CAAC,cACjElB,KAAA,MAAAW,QAAA,eAAGb,IAAA,WAAAa,QAAA,CAAQ,UAAQ,CAAQ,CAAC,IAAC,cAAAX,KAAA,SAAAW,QAAA,EAAOR,IAAI,CAACmB,OAAO,CAACC,MAAM,CAAC,IAAE,CAACpB,IAAI,CAACmB,OAAO,CAACE,IAAI,CAAC,IAAE,CAACrB,IAAI,CAACmB,OAAO,CAACG,OAAO,EAAO,CAAC,EAAG,CAAC,cAChHzB,KAAA,MAAAW,QAAA,eAAGb,IAAA,WAAAa,QAAA,CAAQ,OAAK,CAAQ,CAAC,IAAC,c